// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  IMAGE
  FILE
}

model Product {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  description String   @default("")
  slug        String
  enabled     Boolean  @default(false)

  // Relations - one to many
  variants    ProductVariant[]
  assets      AssetOnProduct[]
  collections ProductOnCollection[]
  labelValues LabelValueOnProduct[]
  options     Option[]

  @@map("product")
}

model Collection {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  description String   @default("")
  slug        String
  enabled     Boolean  @default(false)

  // Relations - one to many
  assets      AssetOnCollection[]
  products    ProductOnCollection[]
  labelValues LabelValueOnCollection[]

  @@map("collection")
}

model Asset {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  name      String
  source    String
  type      AssetType @default(IMAGE)

  // Relations - one to many
  products    AssetOnProduct[]
  collections AssetOnCollection[]
  variants    ProductVariant[]
  labelValues LabelValueOnAsset[]

  @@map("asset")
}

model Label {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String

  // Relations - one to many
  values LabelValue[]

  @@map("label")
}

model LabelValue {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  value     String

  // Relations - one to many
  products    LabelValueOnProduct[]
  collections LabelValueOnCollection[]
  assets      LabelValueOnAsset[]

  // Relations - many to one
  label   Label  @relation(fields: [labelId], references: [id])
  labelId String

  @@map("label_value")
}

model ProductVariant {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  price     Int      @default(0)
  stock     Int      @default(0)
  sku       String
  enabled   Boolean  @default(false)

  // Relations - one to many
  optionValues OptionValueOnProductVariant[]

  // Relations - many to one
  asset     Asset?  @relation(fields: [assetId], references: [id])
  assetId   String?
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@map("product_variant")
}

model Option {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String

  // Relations - one to many
  values OptionValue[]

  // Relations - many to one
  product   Product @relation(fields: [productId], references: [id])
  productId String

  @@map("option")
}

model OptionValue {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  value     String

  // Relations - one to many
  variants OptionValueOnProductVariant[]

  // Relations - many to one
  option   Option @relation(fields: [optionId], references: [id])
  optionId String

  @@map("option_value")
}

model OptionValueOnProductVariant {
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  variantId   String
  optionValue OptionValue    @relation(fields: [optionId], references: [id])
  optionId    String

  @@id([variantId, optionId])
  @@map("option_value_on_product_variant")
}

model LabelValueOnProduct {
  product      Product    @relation(fields: [productId], references: [id])
  productId    String
  labelValue   LabelValue @relation(fields: [labelValueId], references: [id])
  labelValueId String

  @@id([productId, labelValueId])
  @@map("label_value_on_product")
}

model LabelValueOnCollection {
  collection   Collection @relation(fields: [collectionId], references: [id])
  collectionId String
  Label        LabelValue @relation(fields: [labelId], references: [id])
  labelId      String

  @@id([collectionId, labelId])
  @@map("label_value_on_collection")
}

model LabelValueOnAsset {
  asset   Asset      @relation(fields: [assetId], references: [id])
  assetId String
  Label   LabelValue @relation(fields: [labelId], references: [id])
  labelId String

  @@id([assetId, labelId])
  @@map("label_value_on_asset")
}

model ProductOnCollection {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product      Product    @relation(fields: [productId], references: [id])
  productId    String
  collection   Collection @relation(fields: [collectionId], references: [id])
  collectionId String

  @@id([productId, collectionId])
  @@map("product_on_collection")
}

model AssetOnProduct {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  position  Int

  product   Product @relation(fields: [productId], references: [id])
  productId String
  asset     Asset   @relation(fields: [assetId], references: [id])
  assetId   String

  @@id([productId, assetId])
  @@map("asset_on_product")
}

model AssetOnCollection {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  position  Int

  collection   Collection @relation(fields: [collectionId], references: [id])
  collectionId String
  asset        Asset      @relation(fields: [assetId], references: [id])
  assetId      String

  @@id([collectionId, assetId])
  @@map("asset_on_collection")
}
